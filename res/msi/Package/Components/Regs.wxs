<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
	<?include ../Includes.wxi?>

	<Fragment>
		<!-- Regs for shortcuts are defined in "Fragments/ShortcutProperties.wxs" -->
		<!-- Component that persists the property values to the registry so they are available during an upgrade/modify -->
		<DirectoryRef Id="INSTALLFOLDER_INNER">
			<Component Id="Product.Registry.InstallFolder" Guid="3196EDA7-9AEF-4705-A0C8-E3F3ECCCB153">
				<RegistryKey Root="HKCR" Key="$(var.RegKeyRoot)">
					<RegistryValue Type="string" Name="INSTALLFOLDER" Value="[INSTALLFOLDER_INNER]" />
				</RegistryKey>
			</Component>

			<Component Id="Product.Registry.DefaultIcon" Guid="6DBF2690-0955-4C6A-940F-634DDA503F49">
				<RegistryKey Root="HKCR" Key="$(var.RegKeyRoot)\DefaultIcon">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe",0' />
				</RegistryKey>
			</Component>

			<Component Id="Product.Registry.CommandPlay" Guid="613C9E4F-2F1F-45A3-96E2-26EBBEBA6B0E">
				<RegistryKey Root="HKCR" Key="$(var.RegKeyRoot)\shell" />
				<RegistryKey Root="HKCR" Key="$(var.RegKeyRoot)\shell\open" />
				<RegistryKey Root="HKCR" Key="$(var.RegKeyRoot)\shell\open\command">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe" --play "%1"' />
				</RegistryKey>
			</Component>

			<Component Id="Product.Registry.URLProtocol" Guid="565BE3F8-23A7-4B9D-B0DE-6D51CC86FC0B">
				<RegistryKey Root="HKCR" Key="ferrydesk">
					<RegistryValue Type="string" Value="URL:FerryDesk Remote" />
					<RegistryValue Type="string" Name="URL Protocol" Value="" />
				</RegistryKey>
			</Component>

			<Component Id="Product.Registry.Command" Guid="BC8D581C-5960-4843-93DC-E347CD43BD49">
				<RegistryKey Root="HKCR" Key="ferrydesk\shell" />
				<RegistryKey Root="HKCR" Key="ferrydesk\shell\open" />
				<RegistryKey Root="HKCR" Key="ferrydesk\shell\open\command">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe" "%1"' />
				</RegistryKey>
				<RegistryKey Root="HKCR" Key="ferrydesk\DefaultIcon">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe",0' />
				</RegistryKey>
			</Component>

			<!-- Legacy callmor:// scheme — preserved so deep-links emitted by
			     pre-rebrand FerryDesk dashboards or third-party scripts still
			     launch the app. Same handler binary, same args. -->
			<Component Id="Product.Registry.URLProtocolCallmor" Guid="565BE3F8-23A7-4B9D-B0DE-6D51CC86FC0C">
				<RegistryKey Root="HKCR" Key="callmor">
					<RegistryValue Type="string" Value="URL:FerryDesk Remote (legacy)" />
					<RegistryValue Type="string" Name="URL Protocol" Value="" />
				</RegistryKey>
			</Component>

			<Component Id="Product.Registry.CommandCallmor" Guid="BC8D581C-5960-4843-93DC-E347CD43BD4A">
				<RegistryKey Root="HKCR" Key="callmor\shell" />
				<RegistryKey Root="HKCR" Key="callmor\shell\open" />
				<RegistryKey Root="HKCR" Key="callmor\shell\open\command">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe" "%1"' />
				</RegistryKey>
				<RegistryKey Root="HKCR" Key="callmor\DefaultIcon">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe",0' />
				</RegistryKey>
			</Component>

			<!--Also register rustdesk:// so existing dashboards / scripts using
			    that scheme still launch the rebranded app. Lets users keep
			    bookmarks / deep-links working through the rename.-->
			<Component Id="Product.Registry.URLProtocolRustdesk" Guid="A1B2C3D4-1111-2222-3333-444455556666">
				<RegistryKey Root="HKCR" Key="rustdesk">
					<RegistryValue Type="string" Value="URL:FerryDesk Remote" />
					<RegistryValue Type="string" Name="URL Protocol" Value="" />
				</RegistryKey>
			</Component>

			<Component Id="Product.Registry.CommandRustdesk" Guid="B2C3D4E5-1111-2222-3333-444455556666">
				<RegistryKey Root="HKCR" Key="rustdesk\shell" />
				<RegistryKey Root="HKCR" Key="rustdesk\shell\open" />
				<RegistryKey Root="HKCR" Key="rustdesk\shell\open\command">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe" "%1"' />
				</RegistryKey>
				<RegistryKey Root="HKCR" Key="rustdesk\DefaultIcon">
					<RegistryValue Type="string" Value='"[INSTALLFOLDER_INNER]$(var.Product).exe",0' />
				</RegistryKey>
			</Component>

			<!--For compatibility with registry values from previous versions-->
			<Component Id="Product.Registry.UninstallApp" Guid="FC1A3D2E-5642-FBD8-CFA6-5ECAC6DE69A8">
				<RegistryKey Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\$(var.Product)" >
					<RegistryValue Type="string" Name="BuildDate" Value="$(var.BuildDate)" />
					<RegistryValue Type="string" Name="share_rdp" Value="" />

					<!--$ArpStart$-->
					<!--$ArpEnd$-->
				</RegistryKey>
			</Component>
		</DirectoryRef>

	</Fragment>
</Wix>
